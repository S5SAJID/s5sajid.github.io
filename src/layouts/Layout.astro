---
interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  canonical?: string;
}

const {
  title,
  description = "SajidUllah Khan | Fullstack Product Engineer & Designer. Building refined digital systems and high-performance platforms.",
  image,
  article,
  canonical,
} = Astro.props;
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.astro";
import SEO from "../components/SEO.astro";
import "../styles/globals.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <!-- Universal/Legacy Fallback (Bundles 16x16, 32x32, 48x48) -->
    <link rel="icon" type="image/x-icon" sizes="any" href="/favicon.ico">
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="W9W1o_j4J_HRlJM2C9OGgy7ckh9ShblypaOEiaMp6oM"
    />
    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
      canonical={canonical}
    />
    <title>{title}</title>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": "https://s5sajid.github.io/",
            "name": "SajidUllah Khan",
            "alternateName": "s5sajid",
            "jobTitle": "Fullstack Product Engineer",
            "gender": "Male",
            "description": "SajidUllah Khan is a FullStack Product Engineer and Designer with 3+ years of experience specializing in building scalable systems and refined user experiences.",
            "email": "mailto:s5sajidyt@gmail.com",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Swat",
              "addressRegion": "Khyber Pakhtunkhwa",
              "addressCountry": "PK"
            },
            "sameAs": [
              "https://github.com/s5sajid",
              "https://www.youtube.com/@s5sajid",
              "https://twitter.com/s5sajid",
              "https://instagram.com/s5sajid"
            ],
            "knowsAbout": [
              "Product Engineering",
              "Full-stack Web Development",
              "Multi-tenant SaaS Architecture",
              "UI/UX Design",
              "Systems Design",
              "Next.js",
              "TypeScript",
              "GSAP Animations",
              "E-commerce Development",
              "Tailwind CSS",
              "Python",
              "AI Solutions"
            ]
          }
        ]
      }
    </script>
    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="7c90024b-f8cb-4165-8c2c-409cc6aab49c"></script>
  </head>
  <body class="relative">
    <Navigation />
    <slot />
    <style is:global>
      @import url("https://fonts.cdnfonts.com/css/bricolage-grotesque");

      body {
        font-family: "Bricolage Grotesque", sans-serif;
        background-color: #ffffff;
        color: #000000;
        overflow-x: hidden;
      }
    </style>
    <Footer />

    <script src="https://cdn.botpress.cloud/webchat/v5.0/inject.js"></script>
    <script src="https://files.bpcontent.cloud/2026/07/23/09/20260723093943-D380W0FE.js" defer></script>
  </body>
</html>
