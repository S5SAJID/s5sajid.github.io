---
interface TimelineItem {
    title: string;
    company: string;
    period: string;
    description: string;
}

const skills = [
    "TypeScript",
    "TanStack Start",
    "Tanstack Query",
    "DB Designing",
    "JavaScript",
    "Next.js",
    "React",
    "React Native",
    "Flutter",
    "Tailwind CSS",
    "Node.js",
    "Python",
    "Flask",
    "Drizzle ORM",
    "Redux",
    "GSAP",
    "HTML",
    "CSS",
    "Bootstrap",
    "System Architecture",
    "UI/UX Design",
    "Prisma",
    "Biome",
    "Cloudflare",
    "Vercel"
];

const timeline: TimelineItem[] = [
    {
        title: "Full-Stack Product Engineer",
        company: "S5PAGES",
        period: "Present",
        description:
            "Architecting a drag-and-drop platform that lets businesses launch scalable e-commerce experiences seamlessly, with workflows specifically optimized for cash-on-delivery economies.",
    },
    {
        title: "Mobile & Web Engineer",
        company: "Independent Projects",
        period: "2023",
        description:
            "Partnering with clients to build intuitive, high-performance applications from the ground up, focusing on clean UX and robust architecture across iOS, Android, and Web.",
    },
    {
        title: "Full-Stack Developer",
        company: "Self-Employed",
        period: "2020-2022",
        description:
            "The foundation years. Mastered front-end fluidity and back-end systems, learning exactly what makes a digital product tick under the hood.",
    },
];
---

<section id="about" class="py-20 border-t border-black">
    <div class="container mx-auto px-6">
        <h2 class="section-title font-bold mb-20">ABOUT ME</h2>

        <div class="flex flex-col md:flex-row gap-12">
            <div class="md:w-1/2">
                <h3 class="text-2xl font-bold mb-6">The Journey</h3>
                <p class="mb-6">
                    Starting with the sweet name of Almighty Allah. Over the
                    last few years, I've always tried to create systems &
                    products to engineering complete digital ecosystems instead
                    of simple web apps because that's what the whole industry is
                    heading towards. I don't just look at the technical stack; I
                    look at the user experience, the system architecture, what
                    the users wants, what are the problems and how to solve it
                    and how it all fits together.
                </p>
                <p class="mb-6">
                    My favorite approach to UI/UX is a blend of minimalism and
                    functional design, shaped by a curated taste and backed by
                    scalable, type-safe, and maintainable architecture. I
                    believe the best software feels effortless to use, which
                    requires obsessive care behind the scenes.
                </p>
                <p>
                    Following the principle of excellence in my work, I build
                    platforms that do more than look good on a screen. They
                    solve real problems for the people who use them, whether
                    it's a complex multi-tenant system or a fluid, animated web
                    experience.
                </p>
            </div>

            <div class="md:w-1/2">
                <h3 class="text-2xl font-bold mb-6">Skills & Tools</h3>
                <div class="flex flex-wrap gap-3 mb-8">
                    {
                        skills.map((skill) => (
                            <span class="skill-pill px-3 py-1 text-xs rounded-full">
                                {skill}
                            </span>
                        ))
                    }
                </div>

                <h3 class="text-2xl font-bold mb-6">Experience</h3>
                <div class="space-y-8">
                    {
                        timeline.map((item) => (
                            <div class="timeline-item">
                                <div class="timeline-dot" />
                                <div>
                                    <h4 class="font-bold">{item.title}</h4>
                                    <p class="text-sm mb-1">
                                        {item.company} · {item.period}
                                    </p>
                                    <p class="text-sm">{item.description}</p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .section-title {
        font-size: 7vw;
        line-height: 0.9;
        letter-spacing: -0.05em;
    }

    .skill-pill {
        border: 1px solid #000;
        transition: all 0.3s ease;
    }

    .skill-pill:hover {
        background-color: #000;
        color: #fff;
    }

    .timeline-item {
        position: relative;
        padding-left: 36px;
    }

    .timeline-item::before {
        content: "";
        position: absolute;
        left: 10px;
        top: 0;
        height: 100%;
        width: 1px;
        background-color: #000;
    }

    .timeline-dot {
        position: absolute;
        left: 6px;
        top: 5px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #000;
    }

    @media (min-width: 768px) {
        .timeline-item {
            padding-left: 60px;
        }
        .timeline-item::before {
            left: 20px;
        }
        .timeline-dot {
            left: 16px;
        }
    }

    @media (max-width: 768px) {
        .section-title {
            font-size: 12vw;
        }
    }
</style>
